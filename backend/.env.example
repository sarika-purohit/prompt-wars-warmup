# ═══════════════════════════════════════════════════════════
# TripFlow AI — Backend Environment Variables
# ═══════════════════════════════════════════════════════════
#
# SECURITY: This file is a TEMPLATE. Copy it to .env and fill
# in your actual values. The .env file is excluded from version
# control via .gitignore to prevent secret exposure.
#
# Setup: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# Google Cloud Project ID (for Firestore and Cloud Logging)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gemini API Key — get one at https://aistudio.google.com/apikey
# Used for AI-powered itinerary generation and adaptation
GEMINI_API_KEY=your-gemini-api-key

# Gemini model identifier — gemini-2.0-flash is recommended
# for fast structured JSON generation at low cost
GEMINI_MODEL=gemini-2.0-flash

# Google Maps API Key — enable in GCP Console > APIs & Services
# Required APIs: Places API (New), Geocoding API, Directions API
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Mock mode — set to "true" to bypass Gemini API calls
# Useful for frontend development and demo mode
USE_MOCK_DATA=false

# Server configuration
PORT=8080
ENVIRONMENT=development

# Frontend URL for CORS whitelist
FRONTEND_URL=http://localhost:5173

# Rate limiting — max requests per minute per client
RATE_LIMIT_PER_MINUTE=20
